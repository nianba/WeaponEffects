Projectiles: {
	SlashChannelProjectile.DisplayName: 斩击引导
	ChargedSlashProjectile.DisplayName: 蓄力斩击
	SlashArcProjectile.DisplayName: 斩击弧光
	SlashArcGlowProjectile.DisplayName: 斩击边光
	SlashHitEffectProjectile.DisplayName: 斩击命中特效
